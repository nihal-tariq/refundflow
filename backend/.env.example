# ── RefundFlow AI — backend configuration ──────────────────────────────
# All values are optional; sane defaults ship in app/config/settings.py.

# ── LLM phrasing layer (optional, provider-agnostic) ───────────────────
# The LLM only phrases replies; the refund DECISION is always deterministic.
# Without a key (or the provider package) the app uses a templated responder.
#
# Choose any provider: anthropic | openai | google_genai | groq | mistral |
# ollama | openai_compatible. Install the matching langchain-* package first
# (see requirements.txt).
LLM_PROVIDER=anthropic

# Model id for the selected provider (e.g. claude-opus-4-8, gpt-4o,
# gemini-2.5-flash, llama-3.3-70b-versatile, mistral-large-latest, llama3.2).
LLM_MODEL=claude-opus-4-8
LLM_TEMPERATURE=0.2

# Generic key/base-url applied to whichever provider is selected. LLM_API_KEY
# takes precedence over the provider-specific keys below. LLM_BASE_URL is for
# self-hosted/proxy endpoints and is REQUIRED for openai_compatible
# (e.g. Together / OpenRouter / vLLM) and for a non-default Ollama host.
LLM_API_KEY=
LLM_BASE_URL=

# Provider-specific keys (used when LLM_API_KEY is unset). ANTHROPIC_API_KEY is
# kept for backward compatibility; with LLM_PROVIDER=anthropic and only this
# set, behavior is unchanged.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=

# Trace / observability database.
DATABASE_URL=sqlite:///./refundflow.db

# Policy knobs (see data/refund_policy.md).
REFUND_WINDOW_DAYS=30
MAX_REFUNDS_PER_6_MONTHS=3
FRAUD_SCORE_THRESHOLD=0.7
FRAUD_ESCALATION_BAND=0.15

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LiveKit voice agent (optional) ─────────────────────────────────────────
# Required only when running voice_agent.py.
# Create a project at https://cloud.livekit.io and copy the credentials.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
